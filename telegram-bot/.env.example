# Скопируй этот файл в `.env` и заполни своими значениями.
# Файл `.env` НЕ коммить — там секреты.

# === Обязательное ===
TELEGRAM_BOT_TOKEN=поставь_сюда_токен_от_BotFather

# === Какой ИИ использовать ===
# llama  — локальная Llama через Ollama (бесплатно, требует ollama serve)
# grok   — облачный xAI Grok (платно, нужен XAI_API_KEY)
LLM_BACKEND=llama

# Для Llama:
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Для Grok (нужно только если LLM_BACKEND=grok):
# XAI_API_KEY=

# === База данных ===
# Оставь пустым — будет SQLite в файле data.db рядом с ботом.
# Или поставь свой postgres DSN: postgresql://user:pass@host:5432/db
DATABASE_URL=

# === Часовой пояс (Украина = 2 зимой, 3 летом) ===
TZ_OFFSET_HOURS=2

# === Twilio (SMS/звонки) — опционально ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TOHA_PHONE_NUMBER=
# RUSLAN_PHONE_NUMBER=

# === Поиск файлов на ПК ===
# Папки, в которых бот ищет файлы. Можно несколько через ; (Windows) или : (Mac/Linux).
# Если не задано — используется Desktop, Documents, Downloads текущего пользователя.
# PC_SEARCH_DIRS=C:\Users\Ruslan\Desktop;D:\Работа

# === OpenAI (для голосового TTS-ответа) — опционально ===
# Если не нужны голосовые ответы — можно не заполнять.
# AI_INTEGRATIONS_OPENAI_BASE_URL=
# AI_INTEGRATIONS_OPENAI_API_KEY=
