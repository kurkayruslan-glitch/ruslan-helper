# Скопируй этот файл в `.env` и заполни своими значениями.
# Файл `.env` НЕ коммить — там секреты!
# На Replit секреты хранятся в Secrets (не в .env файле).

# ────────────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНОЕ
# ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=поставь_сюда_токен_от_BotFather

# ID Руслана в Telegram (бот отвечает только ему)
OWNER_ID=7959647798

# Секретный код для /secret (опционально, защита от чужих)
# BOT_SECRET_CODE=придумай_свой_код

# ────────────────────────────────────────────────────────────
# ВЫБОР ИИ-БЭКЕНДА (LLM_BACKEND)
# ────────────────────────────────────────────────────────────
# openai  — ChatGPT (рекомендуется, нужен OPENAI_API_KEY)
# grok    — облачный xAI Grok (нужен XAI_API_KEY)
# gemini  — Google Gemini (нужен GEMINI_API_KEY)
# llama   — локальная Llama через Ollama (бесплатно, только на ПК)
LLM_BACKEND=openai

# --- OpenAI (ChatGPT) ---
# Для запуска на ПК:
# OPENAI_API_KEY=sk-...
# Для Replit используется встроенная AI-интеграция (ключ ставится в Secrets):
# AI_INTEGRATIONS_OPENAI_BASE_URL=...
# AI_INTEGRATIONS_OPENAI_API_KEY=...

# --- xAI Grok ---
# XAI_API_KEY=xai-...

# --- Google Gemini ---
# GEMINI_API_KEY=AIza...

# --- Локальная Llama (только на ПК, требует `ollama serve`) ---
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ────────────────────────────────────────────────────────────
# БАЗА ДАННЫХ
# ────────────────────────────────────────────────────────────
# Оставь пустым → SQLite (файл data.db рядом с ботом, работает сразу)
# Или поставь PostgreSQL DSN: postgresql://user:pass@host:5432/db
DATABASE_URL=

# ────────────────────────────────────────────────────────────
# ТЕЛЕФОНЫ
# ────────────────────────────────────────────────────────────
# TOHA_PHONE_NUMBER=+380XXXXXXXXX
# RUSLAN_PHONE_NUMBER=+380XXXXXXXXX
# WIFE_PHONE_NUMBER=+380XXXXXXXXX

# ────────────────────────────────────────────────────────────
# TWILIO (SMS и звонки — опционально)
# ────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# ────────────────────────────────────────────────────────────
# CRM (опционально — интеграция с nginx/Cloudflare CRM)
# ────────────────────────────────────────────────────────────
# CRM_BASE_URL=https://your-crm.example.com
# CRM_COOKIE=...

# ────────────────────────────────────────────────────────────
# ПОИСК ФАЙЛОВ НА ПК (опционально)
# ────────────────────────────────────────────────────────────
# Папки для поиска через ; (Windows) или : (Linux/Mac)
# Если не задано → Desktop, Documents, Downloads текущего пользователя
# PC_SEARCH_DIRS=C:\Users\Ruslan\Desktop;D:\Работа
