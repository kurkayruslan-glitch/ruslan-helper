modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "cloudrun"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-sheet:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 18297
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["postgresql", "xcodebuild", "zlib"]

[userenv]

[userenv.shared]
RUSLAN_PHONE_NUMBER = "+380933129999"
